# Copy to .env.prod on the VPS (never commit). Used by docker/compose.prod.yml

POSTGRES_USER=onemore
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=onemore

WEB_APP_URL=https://app.onemore.com
API_PUBLIC_URL=https://api.onemore.com

ONEMORE_API_IMAGE=ghcr.io/kevinlicenji/onemore-api:latest
ONEMORE_WEB_IMAGE=ghcr.io/kevinlicenji/onemore-web:latest

# PEM strings — escape newlines as \n or mount secrets separately (never use test fixtures in prod)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Email (forgot password, GDPR export notifications)
RESEND_API_KEY=
EMAIL_FROM=onemore@onemore.com

# Web push (optional — leave empty to disable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@onemore.com

# Observability (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# OAuth (optional — leave empty to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.onemore.com/api/v1/auth/oauth/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://api.onemore.com/api/v1/auth/oauth/apple/callback
