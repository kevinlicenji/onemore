{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_E2E_BYPASS", "NEXT_PUBLIC_SENTRY_DSN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "RUN_INTEGRATION_TESTS",
        "DATABASE_URL",
        "REDIS_URL",
        "JWT_PRIVATE_KEY_PATH",
        "JWT_PUBLIC_KEY_PATH",
        "WEB_APP_URL"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
