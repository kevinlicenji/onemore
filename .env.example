# --- Shared / root reference (copy to services/api/.env and apps/web/.env.local) ---

# API (services/api/.env)
NODE_ENV=development
API_PORT=4000
API_VERSION=0.1.0
LOG_LEVEL=info

# Direct Postgres for migrations; app may use PgBouncer in production
DATABASE_URL=postgresql://onemore:onemore_dev@localhost:55432/onemore

# Optional in Phase 0
REDIS_URL=redis://localhost:6380

# Required before auth implementation (Phase 1) — min 32 chars
JWT_SECRET=change-me-use-a-long-random-secret-min-32-chars

# Web (apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
